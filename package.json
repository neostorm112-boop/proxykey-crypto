{
  "name": "proxykey-crypto",
  "version": "0.1.0",
  "type": "module",
  "description": "Envelope encryption (AES-256-GCM, KEK/DEK) used by proxykey to store API keys at rest — published for transparency",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/neostorm112-boop/proxykey-crypto.git"
  },
  "homepage": "https://proxykey.org/en/security/",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "build": "npm run clean && tsc",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.5"
  }
}
